{
  "_comment": "Copy this file to config.json and fill in your SentinelOne SDL API details. config.json is gitignored — never commit real tokens. Only the keys you need are required: log_write_key for ingestion, log_read_key for queries, config_read_key for listFiles/getFile, config_write_key for putFile. A console_api_token covers everything except uploadLogs (set s1_scope if your user has access to multiple sites/accounts).",
  "base_url": "https://<your-tenant>.sentinelone.net",
  "log_write_key": "<PASTE_LOG_WRITE_KEY_OR_LEAVE_BLANK>",
  "log_read_key": "<PASTE_LOG_READ_KEY_OR_LEAVE_BLANK>",
  "config_read_key": "<PASTE_CONFIG_READ_KEY_OR_LEAVE_BLANK>",
  "config_write_key": "<PASTE_CONFIG_WRITE_KEY_OR_LEAVE_BLANK>",
  "console_api_token": "",
  "s1_scope": "",
  "verify_tls": true,
  "timeout_seconds": 30
}
