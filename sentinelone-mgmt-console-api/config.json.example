{
  "_comment": "SentinelOne Management Console API credentials. Update the values below. Do NOT commit this file to source control.",
  "_tokens_comment": "Both api_token and api_token_single_scope are OPTIONAL — configure whichever you have. api_token is the general-purpose token (may cover one or more scopes). api_token_single_scope is used by tests/endpoints that reject multi-scope tokens, notably /threat-intelligence/iocs (HTTP 403 code 4030010 'This page doesn't support multi-scopes users yet'). If you only configure api_token, single-scope-requiring tests will still try with it and skip cleanly if the endpoint rejects it. Request explicitly via S1Client(token_kind='single_scope').",
  "base_url": "https://usea1-purple.sentinelone.net",
  "api_token": "<SERVICE_USER_TOKEN>",
  "_uam_token_single_scope": "This is optional config"
  "api_token_single_scope": "",
  "api_token_single_scope_account_name": "",
  "api_token_single_scope_account_id": "",
  "verify_tls": true,
  "timeout_seconds": 60,
  "default_account_ids": [],
  "default_site_ids": [],
  "_uam_alert_interface_comment": "Optional. UAM (Unified Alert Management) Alert Interface base URL for POSTing OCSF indicators/alerts via /v1/indicators and /v1/alerts. Host differs from base_url (scalyr-family infra). Defaults to https://ingest.us1.sentinelone.net (US1 prod) when unset.Auth on these endpoints is 'Bearer <JWT>' not 'ApiToken <JWT>'. Legacy key ingestion_gateway_url is still honored as a fallback.",
  "uam_alert_interface_url": "https://ingest.us1.sentinelone.net"
}
